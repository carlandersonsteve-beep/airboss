# Copy this file to .env for local development.
# AirBoss uses a thin Node backend plus Postgres.

PORT=8787

# Required for hosted deployments. Change this from the dev default.
SESSION_SECRET=change-me-before-hosting

# Use your Postgres connection string here.
# Supabase can back this, but AirBoss talks to it through Postgres/DATABASE_URL,
# not through a browser-only client.
# Example:
# DATABASE_URL=postgres://postgres:password@127.0.0.1:5432/airboss
DATABASE_URL=
